{
  "name": "md2wechat",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "npm --prefix web run dev",
    "dev:api": "go run ./cmd/md2wechat --no-open --article-root articles",
    "build": "npm --prefix web run build",
    "build:server": "go build -tags release -o release/md2wechat ./cmd/md2wechat",
    "release:windows": "go run ./tools/release/windows",
    "lint": "npm --prefix web run lint",
    "test": "npm --prefix web run test",
    "test:watch": "npm --prefix web run test:watch"
  }
}
